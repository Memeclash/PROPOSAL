      S.tableCols.forEach((c,ci)=>{
        if(ci===lastColIdx){feesCtx.fillText(c,rightX-feesCtx.measureText(c).width,fy+22);}
        else{feesCtx.fillText(c,feesBx.x+ci*otherColW+10,fy+22);}
      });fy+=36;
      let lastColTotal=0;
      S.tableRows.forEach((row,ri)=>{
        if(ri%2===0){feesCtx.fillStyle='#f8f8f8';feesCtx.fillRect(feesBx.x,fy-4,feesBx.w,30);}
        row.forEach((cell,ci)=>{
          if(ci===lastColIdx){
            // Fee column: format as money, right-aligned
            const n=parseFloat(String(cell).replace(/[\u00a3,]/g,''));
            if(!isNaN(n))lastColTotal+=n;
            const moneyStr=fmtMoney(cell);
            feesCtx.font='600 19px Barlow, sans-serif';feesCtx.fillStyle='#111b2f';
            feesCtx.fillText(moneyStr,rightX-feesCtx.measureText(moneyStr).width,fy+16);
          }else{
            feesCtx.font='300 17px Barlow, sans-serif';feesCtx.fillStyle='#2a3347';
            feesCtx.fillText(cell,feesBx.x+ci*otherColW+10,fy+16);
          }
        });
        feesCtx.strokeStyle='#eee';feesCtx.lineWidth=1;feesCtx.beginPath();feesCtx.moveTo(feesBx.x,fy+26);feesCtx.lineTo(feesBx.x+feesBx.w,fy+26);feesCtx.stroke();fy+=30;
      });
      fy+=8;feesCtx.strokeStyle='#111b2f';feesCtx.lineWidth=2.5;feesCtx.beginPath();feesCtx.moveTo(feesBx.x,fy);feesCtx.lineTo(feesBx.x+feesBx.w,fy);feesCtx.stroke();fy+=22;
      feesCtx.font='600 19px Barlow, sans-serif';feesCtx.fillStyle='#111b2f';const tts=fmtMoney(lastColTotal);feesCtx.fillText(tts,rightX-feesCtx.measureText(tts).width,fy);fy+=26;
    }
    // Terms
    fy+=20;feesCtx.strokeStyle='#e0e0e0';feesCtx.lineWidth=2;feesCtx.beginPath();feesCtx.moveTo(feesBx.x,fy);feesCtx.lineTo(rightX,fy);feesCtx.stroke();fy+=26;
    feesCtx.font='600 17px Barlow, sans-serif';feesCtx.fillStyle='#111b2f';feesCtx.fillText('TERMS & CONDITIONS',feesBx.x,fy);fy+=22;
    ['1. Fees are exclusive of VAT and will be invoiced in accordance with the payment schedule outlined above.','2. Payment is due within 30 days of the invoice date.','3. This engagement is subject to our standard terms of business, a copy of which is available on request.','4. We reserve the right to revise fees where the scope of work changes materially from that described above.','5. Either party may terminate this engagement by providing 30 days\' written notice.','6. Our work will be carried out in accordance with applicable professional standards and regulations.','7. This proposal is valid for 30 days from the date of issue.'].forEach(t=>{
      feesCtx.font='300 15px Barlow, sans-serif';feesCtx.fillStyle='#888888';const words=t.split(' ');let line='';
      words.forEach(w=>{const test=line?line+' '+w:w;if(feesCtx.measureText(test).width>feesBx.w){fy+=20;feesCtx.fillText(line,feesBx.x,fy);line=w;}else{line=test;}});
      fy+=20;feesCtx.fillText(line,feesBx.x,fy);
    });
  }

  // PAGE 6 (index 5): Additional Services
  const b5=BOXES[5],c5=canvases[5].getContext('2d');clearBox(c5,b5.fill);
  const hasExtras=ADDITIONAL_SERVICES.some(s=>S.selectedAdditional[s.id])||S.customAdditional.some(c=>c.title&&c.text);
  if(hasExtras){
    let y5=drawHeading(c5,'Other Ways We Can Help',b5.text.x,b5.text.y);
    function drawSvc(title,text){y5+=12;c5.font='600 20px Barlow, sans-serif';c5.fillStyle='#FF8D64';c5.fillText(title,b5.text.x,y5+20);y5+=30;c5.font='300 18px Barlow, sans-serif';c5.fillStyle='#2a3347';const words=text.split(' ');let line='';words.forEach(w=>{const test=line?line+' '+w:w;if(c5.measureText(test).width>b5.text.w){y5+=26;c5.fillText(line,b5.text.x,y5);line=w;}else{line=test;}});y5+=26;c5.fillText(line,b5.text.x,y5);y5+=12;}
    ADDITIONAL_SERVICES.forEach(svc=>{if(S.selectedAdditional[svc.id])drawSvc(svc.title,S.additionalTexts[svc.id]||svc.text);});
    S.customAdditional.forEach(c=>{if(c.title&&c.text)drawSvc(c.title,c.text);});
  }

  container.innerHTML='';const labels=['Front Page','About Us','Scope of Work','Scope / Fees (cont.)','Scope / Fees (cont. 2)','Additional Services'];
  const pageNums=['1','2','3','4','4.1','5'];
  canvases.forEach((c,i)=>{const wrap=document.createElement('div');wrap.className='page-wrapper';wrap.style.width='700px';const dc=document.createElement('canvas');dc.width=W;dc.height=H;dc.style.width='100%';dc.style.height='auto';dc.getContext('2d').drawImage(c,0,0);wrap.appendChild(dc);const lbl=document.createElement('label');lbl.className='page-check';lbl.innerHTML=`<input type="checkbox" ${S.pageChecked[i]?'checked':''} onchange="S.pageChecked[${i}]=this.checked"> Include <strong>Page ${pageNums[i]}</strong> \u2014 ${labels[i]}`;wrap.appendChild(lbl);container.appendChild(wrap);});
  window._previewCanvases=canvases;
}

async function generatePDF(){
  const btn=document.getElementById('dlBtn');btn.textContent='Generating\u2026';btn.disabled=true;
  if(!window._previewCanvases)await renderPreview();const canvases=window._previewCanvases;const{jsPDF}=window.jspdf;let pdf=null,first=true;
  for(let i=0;i<canvases.length;i++){if(!S.pageChecked[i])continue;const imgData=canvases[i].toDataURL('image/jpeg',0.92);
    if(first){pdf=new jsPDF({unit:'px',format:[1413,2000],orientation:'portrait',hotfixes:['px_scaling']});pdf.addImage(imgData,'JPEG',0,0,1413,2000);first=false;}
    else{pdf.addPage([1413,2000],'portrait');pdf.addImage(imgData,'JPEG',0,0,1413,2000);}}
  if(pdf)pdf.save('Proposal - '+(S.clientName||'Client')+'.pdf');btn.textContent='Download PDF';btn.disabled=false;
}

render();

</script>
