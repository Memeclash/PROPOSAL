function fmtMoney(v){const n=parseFloat(v);return isNaN(n)?'TBC':'\u00a3'+n.toLocaleString('en-GB',{minimumFractionDigits:2})}
function clearBox(ctx,fb){ctx.fillStyle='#ffffff';ctx.fillRect(fb.x,fb.y,fb.w,fb.h);}

const BFS=20, BLH=1.55;

function wrapText(ctx,text,box,fs,opts){
  opts=opts||{};const lh=fs*(opts.lineSpacing||BLH);
  ctx.font=(opts.weight||'300')+' '+fs+'px Barlow, sans-serif';ctx.fillStyle=opts.color||'#2a3347';
  const maxW=box.w,yBot=box.y+box.h;let y=box.y+fs;
  const paras=text.split('\n');
  for(let pi=0;pi<paras.length;pi++){
    const para=paras[pi];
    if(!para.trim()){y+=lh*0.45;if(y+lh>yBot)return paras.slice(pi).join('\n');continue;}
    const words=para.split(/\s+/);let line='';
    for(let wi=0;wi<words.length;wi++){
      const test=line?line+' '+words[wi]:words[wi];
      if(ctx.measureText(test).width>maxW&&line){if(y>yBot)return(line+' '+words.slice(wi).join(' ')).trim()+'\n'+paras.slice(pi+1).join('\n');ctx.fillText(line,box.x,y);y+=lh;line=words[wi];}
      else{line=test;}
    }
    if(line){if(y>yBot)return line+'\n'+paras.slice(pi+1).join('\n');ctx.fillText(line,box.x,y);y+=lh;}
    y+=lh*0.25;
  }
  return null;
}
function measureText(ctx,text,box,fs,opts){
  opts=opts||{};const lh=fs*(opts.lineSpacing||BLH);
  ctx.font=(opts.weight||'300')+' '+fs+'px Barlow, sans-serif';const maxW=box.w;let h=fs;
  for(const para of text.split('\n')){
    if(!para.trim()){h+=lh*0.45;continue;}let line='';
    for(const w of para.split(/\s+/)){const test=line?line+' '+w:w;if(ctx.measureText(test).width>maxW&&line){h+=lh;line=w;}else{line=test;}}
    if(line)h+=lh;h+=lh*0.25;
  }
  return h;
}
function drawHeading(ctx,title,x,y){
  ctx.font='500 32px Barlow Condensed, sans-serif';ctx.fillStyle='#111b2f';
  ctx.fillText(title.toUpperCase(),x,y+32);
  const tw=ctx.measureText(title.toUpperCase()).width;
  ctx.fillStyle='#65F9E5';ctx.fillRect(x,y+38,tw,3);
  return y+62;
}
function drawFeeGroup(ctx,label,svcs,x,rightX,startY){
  const rowH=34;let y=startY;
  // Group label (orange)
  ctx.font='600 18px Barlow, sans-serif';ctx.fillStyle='#FF8D64';
  ctx.fillText(label.toUpperCase(),x,y);y+=16;
  let total=0;
  svcs.forEach((s,si)=>{
    const p=S.menuPrices[s];const n=parseFloat(p);if(!isNaN(n))total+=n;
    y+=rowH;
    ctx.font='300 19px Barlow, sans-serif';ctx.fillStyle='#2a3347';ctx.fillText(s,x,y);
    ctx.font='600 19px Barlow, sans-serif';ctx.fillStyle='#111b2f';const money=fmtMoney(p);ctx.fillText(money,rightX-ctx.measureText(money).width,y);
    // Thin line after each service row
    ctx.strokeStyle='#f0f0f0';ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(x,y+12);ctx.lineTo(rightX,y+12);ctx.stroke();
  });
  // Bold line under the last service (before total)
  y+=14;ctx.strokeStyle='#111b2f';ctx.lineWidth=2.5;ctx.beginPath();ctx.moveTo(x,y);ctx.lineTo(rightX,y);ctx.stroke();
  // Total row
  y+=26;ctx.font='600 19px Barlow, sans-serif';ctx.fillStyle='#111b2f';ctx.fillText('Total',x,y);const ts=fmtMoney(total);ctx.fillText(ts,rightX-ctx.measureText(ts).width,y);
  y+=36;return y;
}

async function renderPreview(){
  const container=document.getElementById('proposal-preview');
  container.innerHTML='<p style="text-align:center;color:#888;padding:20px">Generating preview\u2026</p>';
  const pageImages=await Promise.all(PAGE_PNGS.map(src=>new Promise((res,rej)=>{const img=new Image();img.onload=()=>res(img);img.onerror=rej;img.src=src;})));
  const d=DEPARTMENTS[S.dept];const dateStr=new Date(S.proposalDate).toLocaleDateString('en-GB',{day:'numeric',month:'long',year:'numeric'});
  const W=1413,H=2000;
  // 6 canvases: 0=cover, 1=about, 2=scope, 3=scope cont, 4=scope/fees, 5=extras
  const canvases=[];
  for(let i=0;i<6;i++){
    const c=document.createElement('canvas');c.width=W;c.height=H;
    // Page 4.1 (index 4) uses same template as page 4 (index 3 in old array)
    const imgIdx=i<=3?i:(i===4?3:4);
    c.getContext('2d').drawImage(pageImages[imgIdx],0,0,W,H);canvases.push(c);
  }

  // PAGE 1
  const b1=BOXES[0],c1=canvases[0].getContext('2d');clearBox(c1,b1.fill);const t1=b1.text;let y1=t1.y+8;
  c1.font='400 22px Barlow Condensed, sans-serif';c1.fillStyle='rgba(101,249,229,0.8)';c1.fillText((d.name+' Proposal').toUpperCase(),t1.x,y1+22);y1+=36;
  c1.fillStyle='rgba(17,27,47,0.12)';c1.fillRect(t1.x,y1,t1.w,1);y1+=14;
  c1.font='500 34px Barlow, sans-serif';c1.fillStyle='#111b2f';c1.fillText(S.clientName||'Client Name',t1.x,y1+34);y1+=46;
  c1.font='300 20px Barlow, sans-serif';c1.fillStyle='#666666';c1.fillText(dateStr,t1.x,y1+20);y1+=28;c1.fillText('Prepared by '+(S.feeEarner||'Fee Earner'),t1.x,y1+20);

  // PAGE 2: About Us - render department-specific about text into the green box area
  {
    const b2=BOXES[1],c2ctx=canvases[1].getContext('2d');
    clearBox(c2ctx,b2.fill);
    const aboutText=S.aboutTextOverride[S.dept]!==undefined?S.aboutTextOverride[S.dept]:d.aboutText;
    if(aboutText){
      let y2=drawHeading(c2ctx,'About Us',b2.text.x,b2.text.y);
      const tb2={x:b2.text.x,y:y2,w:b2.text.w,h:b2.text.y+b2.text.h-y2};
      wrapText(c2ctx,aboutText,tb2,BFS);
    }
  }

  // PAGE 3: Scope
  const b3=BOXES[2],c3=canvases[2].getContext('2d');clearBox(c3,b3.fill);
  let y3=drawHeading(c3,'Scope',b3.text.x,b3.text.y);
  const tb3={x:b3.text.x,y:y3,w:b3.text.w,h:b3.text.y+b3.text.h-y3};
  const overflow=wrapText(c3,S.scope,tb3,BFS);
  const scopeH3=measureText(c3,S.scope,tb3,BFS);
  const p3End=y3+Math.min(scopeH3,tb3.h),p3Left=b3.text.y+b3.text.h-p3End;

  // PAGE 4: Scope continued (first overflow)
  const b4=BOXES[3],c4=canvases[3].getContext('2d');clearBox(c4,b4.fill);
  let overflow2=null;
  let feesCtx,feesY,feesBx;const hasFees=S.selectedServices.length>0||S.useTable;
  if(overflow){
    let y4=drawHeading(c4,'Scope (continued)',b4.text.x,b4.text.y);
    const tb4={x:b4.text.x,y:y4,w:b4.text.w,h:b4.text.y+b4.text.h-y4};
    overflow2=wrapText(c4,overflow,tb4,BFS);
    const scopeH4=measureText(c4,overflow,tb4,BFS);
    const p4End=y4+Math.min(scopeH4,tb4.h),p4Left=b4.text.y+b4.text.h-p4End;
    if(!overflow2&&hasFees&&p4Left>350){feesCtx=c4;feesY=p4End+20;feesBx=b4.text;}
  }else{
    if(hasFees&&p3Left>350){feesCtx=c3;feesY=p3End+10;feesBx=b3.text;}
    else if(hasFees){feesCtx=c4;feesY=b4.text.y+10;feesBx=b4.text;}
  }

  // PAGE 4.1 (index 4): Second scope overflow page
  const b41=BOXES[4],c41=canvases[4].getContext('2d');clearBox(c41,b41.fill);
  if(overflow2){
    let y41=drawHeading(c41,'Scope (continued)',b41.text.x,b41.text.y);
    const tb41={x:b41.text.x,y:y41,w:b41.text.w,h:b41.text.y+b41.text.h-y41};
    wrapText(c41,overflow2,tb41,BFS);
    const scopeH41=measureText(c41,overflow2,tb41,BFS);
    const p41End=y41+Math.min(scopeH41,tb41.h),p41Left=b41.text.y+b41.text.h-p41End;
    if(hasFees&&p41Left>350){feesCtx=c41;feesY=p41End+20;feesBx=b41.text;}
    else if(hasFees&&!feesCtx){feesCtx=c41;feesY=b41.text.y+10;feesBx=b41.text;}
  }else if(!feesCtx&&hasFees){
    // If fees haven't been placed yet, put them on page 4.1
    feesCtx=c41;feesY=b41.text.y+10;feesBx=b41.text;
  }

  // FEES
  if(feesCtx&&hasFees){
    let fy=drawHeading(feesCtx,'Fees',feesBx.x,feesY);fy+=14;const rightX=feesBx.x+feesBx.w;
    const groups={annual:[],quarterly:[],monthly:[],oneoff:[]};
    S.selectedServices.forEach(s=>{groups[S.feeFrequency[s]||'annual'].push(s);});
    if(groups.annual.length)fy=drawFeeGroup(feesCtx,'Annual Fees',groups.annual,feesBx.x,rightX,fy);
    if(groups.quarterly.length)fy=drawFeeGroup(feesCtx,'Quarterly Fees',groups.quarterly,feesBx.x,rightX,fy);
    if(groups.monthly.length)fy=drawFeeGroup(feesCtx,'Monthly Fees',groups.monthly,feesBx.x,rightX,fy);
    if(groups.oneoff.length)fy=drawFeeGroup(feesCtx,'One-off Fees',groups.oneoff,feesBx.x,rightX,fy);
    if(S.useTable){
      fy+=10;
      const numCols=S.tableCols.length;
      const lastColIdx=numCols-1;
      // Column widths: non-fee columns share the space, fee column is right-aligned to rightX
      const feeColW=200;
