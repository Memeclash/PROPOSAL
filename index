function renderStep2(){const d=DEPARTMENTS[S.dept];let h=`<h2>Select Services &mdash; ${d.name}</h2><p class="hint">Tick services to include. You can also add a custom pricing table below.</p><div class="svc-grid">${d.services.map(s=>`<div class="svc-item ${S.selectedServices.includes(s)?'selected':''}" onclick="toggleSvc('${esc(s)}')"><div class="svc-check">${S.selectedServices.includes(s)?'&#10003;':''}</div><span>${s}</span></div>`).join("")}</div><div style="display:flex;gap:8px;margin-top:12px"><input id="customSvcInput" style="flex:1;padding:10px 12px;border:2px solid #e0e0e0;border-radius:6px;font-size:13px" placeholder="Add a custom service..." onkeydown="if(event.key==='Enter')addCustomSvc()"><button class="btn btn-sm btn-primary" onclick="addCustomSvc()">Add</button></div><div style="margin-top:24px;padding-top:16px;border-top:1px solid #e0e0e0"><div style="display:flex;align-items:center;gap:10px;margin-bottom:12px"><div class="svc-item ${S.useTable?'selected':''}" onclick="S.useTable=!S.useTable;render()" style="display:inline-flex;cursor:pointer"><div class="svc-check">${S.useTable?'&#10003;':''}</div><span style="font-weight:600">Also include a custom pricing table</span></div></div></div>`;if(S.useTable){h+=`<div style="display:flex;gap:6px;margin-bottom:10px"><button class="btn btn-sm btn-outline" onclick="addTableCol()">+ Column</button><button class="btn btn-sm btn-outline" onclick="addTableRow()">+ Row</button></div><table class="tbl-builder"><thead><tr>`;S.tableCols.forEach((c,i)=>{h+=`<th><input value="${c}" onchange="S.tableCols[${i}]=this.value">${S.tableCols.length>2?`<button class="col-remove" onclick="removeTableCol(${i})">&#215;</button>`:''}</th>`;});h+=`<th style="width:30px"></th></tr></thead><tbody>`;S.tableRows.forEach((row,ri)=>{h+='<tr>';row.forEach((cell,ci)=>{h+=`<td><input value="${cell}" onchange="S.tableRows[${ri}][${ci}]=this.value"></td>`;});h+=`<td>${S.tableRows.length>1?`<button class="row-remove" onclick="removeTableRow(${ri})">&#215;</button>`:''}</td></tr>`;});h+='</tbody></table>';}return h;}
function renderStep3(){if(S.selectedServices.length===0)return`<h2>Pricing</h2><p class="hint">No standard services selected. If you added a custom table, pricing will come from there.</p>`;let h=`<h2>Pricing</h2><p class="hint">Set the fee and frequency for each service.</p>`;h+=S.selectedServices.map(s=>`<div class="price-row"><span class="svc-name">${s}</span><select onchange="S.feeFrequency['${esc(s)}']=this.value"><option value="annual" ${(S.feeFrequency[s]||'annual')==='annual'?'selected':''}>Annual</option><option value="quarterly" ${S.feeFrequency[s]==='quarterly'?'selected':''}>Quarterly</option><option value="monthly" ${S.feeFrequency[s]==='monthly'?'selected':''}>Monthly</option><option value="oneoff" ${S.feeFrequency[s]==='oneoff'?'selected':''}>One-off</option></select><div style="display:flex;align-items:center;gap:3px"><span style="font-weight:600;color:#666">\u00a3</span><input value="${S.menuPrices[s]||''}" onchange="S.menuPrices['${esc(s)}']=this.value" placeholder="0.00"></div></div>`).join("");return h;}
