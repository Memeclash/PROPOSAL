    .pdf-page .terms h4{font-size:8pt;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:var(--navy);margin-bottom:6px}
    .pdf-page .terms p{font-size:7pt;color:#888;margin-bottom:2px;line-height:1.5}
    .pdf-page .extra-svc{margin-bottom:12px}
