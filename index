    .pdf-page .extra-svc p{font-size:7.5pt}
    .pdf-page .custom-tbl{width:100%;border-collapse:collapse;font-size:8pt;margin-bottom:12px}
    .pdf-page .custom-tbl th{padding:5px 8px;background:var(--navy);color:#fff;font-weight:500;text-align:left;font-size:7.5pt}
    .pdf-page .custom-tbl td{padding:5px 8px;border-bottom:1px solid #eee}
    .pdf-page .custom-tbl tr:nth-child(even) td{background:#fafafa}
    .pdf-page .custom-tbl .tbl-total td{background:none;border-top:2px solid var(--navy);font-weight:600;padding-top:6px}

    #proposal-preview{display:none}
    #proposal-preview.visible{display:flex;flex-direction:column;align-items:center;gap:20px;margin:20px auto;padding-bottom:40px}
  
    /* Canvas preview styles */
    .canvas-preview-area{display:none;flex-direction:column;align-items:center;gap:20px;margin:20px auto;padding-bottom:40px}
    .canvas-preview-area.visible{display:flex}
    .page-wrapper{position:relative}
    .page-wrapper canvas{box-shadow:0 2px 12px rgba(0,0,0,.15);max-width:100%}
    .page-check{display:flex;align-items:center;gap:8px;margin-top:8px;font-size:13px;font-weight:500}
    .page-check input[type=checkbox]{width:18px;height:18px;accent-color:var(--teal)}

  </style>
</head>
