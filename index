    .pdf-page .inner-body p{font-size:8pt;line-height:1.8;color:#2a3347;margin-bottom:10px;font-weight:300;white-space:pre-wrap}
    .pdf-page .fee-section{margin-bottom:14px}
    .pdf-page .fee-label{font-size:8pt;font-weight:600;color:var(--orange);text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px}
    .pdf-page .fee-row{display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px solid #f0f0f0;font-size:8pt}
    .pdf-page .fee-row .fn{font-weight:400;color:#2a3347}.pdf-page .fee-row .fa{font-weight:600;color:var(--navy)}
